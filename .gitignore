# -----------------------------------------------------------------------------
# makepkg build directories
# -----------------------------------------------------------------------------

**/src/
**/pkg/

# -----------------------------------------------------------------------------
# Temporary files
# -----------------------------------------------------------------------------

*.log
*.tmp
*.cache

# -----------------------------------------------------------------------------
# Vim / Neovim
# -----------------------------------------------------------------------------

*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# macOS
# -----------------------------------------------------------------------------

.DS_Store

# -----------------------------------------------------------------------------
# VSCode
# -----------------------------------------------------------------------------

.vscode/

# -----------------------------------------------------------------------------
# JetBrains
# -----------------------------------------------------------------------------

.idea/

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------

__pycache__/
*.py[cod]

# -----------------------------------------------------------------------------
# Keep package outputs in package directories out of git
# (they are copied into repo/x86_64/)
# -----------------------------------------------------------------------------

pkgs/**/*.pkg.tar.*
pkgs/**/*.pkg.tar.*.sig

# -----------------------------------------------------------------------------
# Ignore generated metadata
# -----------------------------------------------------------------------------

pkgs/**/.BUILDINFO
pkgs/**/.MTREE
pkgs/**/.PKGINFO

# -----------------------------------------------------------------------------
# IMPORTANT:
# We DO want these in Git
# -----------------------------------------------------------------------------

!repo/
!repo/x86_64/
!repo/x86_64/*
